<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Login</title>
</head>
<body class="bg-slate-900 flex items-center justify-center min-h-screen">
    <div class="bg-white p-12 rounded-[40px] shadow-2xl w-full max-w-md text-center">
        <h1 class="text-4xl font-black text-blue-600 mb-2 uppercase tracking-tighter">Welcome Back</h1>
        <p class="text-gray-400 font-medium mb-10 text-sm">Login to your account</p>
        
        <form action="/login" method="POST" class="space-y-4 text-left">
            <input type="email" name="email" placeholder="Email Address" required class="w-full p-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none font-medium">
            <input type="password" name="password" placeholder="Password" required class="w-full p-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none font-medium">
            <button type="submit" class="w-full py-4 bg-blue-600 text-white rounded-2xl font-black text-lg hover:bg-blue-700 transition shadow-lg shadow-blue-200">Sign In</button>
        </form>
        
        <p class="mt-8 text-sm font-bold text-gray-400">New here? <a href="/register" class="text-blue-600 hover:underline">Create account</a></p>
    </div>
</body>
</html>