<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Cart</title>
</head>
<body class="bg-gray-50">
    <nav class="bg-white border-b sticky top-0 z-50 px-8 py-4 flex justify-between">
        <h1 class="text-2xl font-black text-blue-600 uppercase tracking-tighter">Mobile Store</h1>
        <div class="flex items-center space-x-4">
            <a href="/user-dashboard" class="text-blue-600 hover:underline">Back to Shop</a>
            <a href="/my-orders" class="text-gray-600 hover:text-blue-600 font-bold transition">My Orders</a>
            <a href="/cart" class="bg-blue-600 text-white px-4 py-1 rounded-full font-bold hover:bg-blue-700">🛒 <span id="count"><%= cartCount %></span></a>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto p-10">
        <h1 class="text-3xl font-bold mb-6">Your Cart</h1>
        <% if (cart.length === 0) { %>
            <p class="text-gray-500">Your cart is empty.</p>
        <% } else { %>
            <div class="grid grid-cols-1 gap-6">
                <% cart.forEach(item => { %>
                    <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex items-center justify-between">
                        <img src="/image/<%= item.image || 'default-phone.jpg' %>" class="h-24 w-24 object-contain" onerror="this.src='/image/default-phone.jpg'">
                        <div class="flex-1 ml-6">
                            <h3 class="text-xl font-bold text-gray-900"><%= item.name %></h3>
                            <p class="text-gray-400 text-sm">$<%= item.price %> each x <%= item.qty %> = $<%= item.price * item.qty %></p>
                        </div>
                        <form action="/cart/remove/<%= item.productId %>" method="post" style="display:inline;">
                            <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded-xl font-bold hover:bg-red-700 transition-colors">Remove</button>
                        </form>
                    </div>
                <% }) %>
            </div>
            <div class="mt-8 text-right">
                <p class="text-xl font-bold">Total: $<%= total %></p>
                <form action="/checkout" method="POST" class="mt-4">
                    <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-blue-700 shadow-lg transition-all transform hover:scale-105">Place Order Now</button>
                </form>
            </div>
        <% } %>
    </main>
</body>
</html>