<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { background-color: #020617; color: white; font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-card { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .accent-gradient { background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%); }
        .text-gradient { background: linear-gradient(135deg, #fff 0%, #94a3b8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        
        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(2deg); }
        }
        .animate-float { animation: float 6s ease-in-out infinite; }

        @keyframes cart-pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.2); color: #22d3ee; }
            100% { transform: scale(1); }
        }
        .cart-animate { animation: cart-pulse 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    </style>
    <title><%= product.name %> | <%= storeName %></title>
</head>
<body class="min-h-screen antialiased selection:bg-cyan-500/30">
    <!-- Decorative Background -->
    <div class="fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-cyan-500/10 blur-[120px]"></div>
        <div class="absolute -bottom-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-blue-600/5 blur-[120px]"></div>
    </div>

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 px-8 py-4 backdrop-blur-xl border-b border-white/5 bg-slate-950/50">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-8">
                <a href="/" class="text-2xl font-black italic tracking-tighter text-white uppercase group">
                    <span class="text-cyan-500 group-hover:text-white transition-colors duration-300">MobileHub</span>.
                </a>
                <div class="hidden md:flex gap-6">
                    <% ui.nav.forEach(item => { %>
                        <a href="<%= item.path %>" class="text-[10px] font-black uppercase tracking-[0.2em] <%= ui.currentPath === item.path ? 'text-cyan-400' : 'text-gray-500 hover:text-white' %> transition-all">
                            <%= item.label %>
                        </a>
                    <% }) %>
                </div>
            </div>
            <div class="flex items-center gap-6">
                <a href="/cart" class="relative group p-2 rounded-xl hover:bg-white/5 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 group-hover:text-cyan-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                    <span id="count" class="absolute -top-1 -right-1 accent-gradient text-[9px] font-black w-4 h-4 flex items-center justify-center rounded-full border border-slate-950">
                        <%= cartCount %>
                    </span>
                </a>
                <a href="/logout" class="text-[10px] font-black uppercase tracking-widest px-5 py-2 rounded-full border border-red-500/20 text-red-400 hover:bg-red-500/10 transition-all">Exit</a>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-12 px-6">
        <div class="mb-12">
            <a href="/user-dashboard" class="inline-flex items-center gap-3 text-[10px] font-black uppercase tracking-[0.2em] text-cyan-500 hover:text-white transition-colors group">
                <span class="w-8 h-8 rounded-full border border-cyan-500/20 flex items-center justify-center group-hover:bg-cyan-500/10 transition-all">&larr;</span>
                Back to Inventory
            </a>
        </div>

        <div class="flex flex-col lg:flex-row gap-16 items-start">
            <div class="lg:sticky lg:top-32 w-full lg:w-1/2 glass-card rounded-[3rem] p-12 flex items-center justify-center aspect-square">
                <img src="<%= product.image ? (product.image.startsWith('/') ? product.image : '/' + product.image) : '/image/default-phone.jpg' %>" 
                     alt="<%= product.name %>" 
                     class="max-h-full object-contain animate-float drop-shadow-[0_20px_50px_rgba(6,182,212,0.3)]"
                     onerror="this.onerror=null; this.src='/image/default-phone.jpg'">
            </div>
            <div class="flex-1 space-y-8">
                <div>
                    <span class="text-xs font-black text-cyan-500 uppercase tracking-[0.3em]"><%= product.brand %></span>
                    <h1 class="text-6xl font-black tracking-tighter text-gradient mt-4 leading-tight"><%= product.name %></h1>
                    <p class="text-4xl font-black mt-6 italic"><%= currencySymbol %><%= formatPrice(product.price) %></p>
                </div>

                <div class="space-y-4 pt-8 border-t border-white/5">
                    <p class="text-[10px] font-black uppercase tracking-widest text-gray-500">Encrypted Specs</p>
                    <p class="text-gray-400 leading-relaxed"><%= product.description %></p>
                </div>

                <div class="grid grid-cols-2 gap-4 pt-8">
                    <div class="glass-card p-6 rounded-3xl">
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Storage Capacity</p>
                        <p class="text-xl font-black text-cyan-400"><%= product.specs.storage %></p>
                    </div>
                    <div class="glass-card p-6 rounded-3xl">
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">System Memory</p>
                        <p class="text-xl font-black text-cyan-400"><%= product.specs.ram %></p>
                    </div>
                    <div class="glass-card p-6 rounded-3xl">
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Display Module</p>
                        <p class="text-xl font-black text-cyan-400"><%= product.specs.screen || 'Retina OLED' %></p>
                    </div>
                    <div class="glass-card p-6 rounded-3xl">
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Classification</p>
                        <p class="text-xl font-black text-cyan-400 capitalize"><%= product.category %></p>
                    </div>
                </div>

                <div class="pt-12">
                    <% if (parseInt(product.stock) > 0) { %>
                        <button onclick="addToCart('<%= product._id %>')" 
                            class="accent-gradient w-full py-6 rounded-full text-slate-950 text-sm font-black uppercase tracking-[0.2em] shadow-2xl shadow-cyan-500/20 hover:scale-[1.02] active:scale-95 transition-all">
                            Deploy to Bag
                        </button>
                    <% } else { %>
                        <div class="w-full py-6 rounded-full border border-red-500/20 text-red-500 text-center font-black uppercase tracking-widest bg-red-500/5">
                            Unit Depleted
                        </div>
                    <% } %>
                    <p class="text-center mt-6 text-[10px] font-bold text-gray-600 uppercase tracking-widest">Stock remaining: <%= product.stock %> units</p>
                </div>
            </div>
        </div>
    </main>

    <script>
        async function addToCart(productId) {
            const countEl = document.getElementById('count');
            try {
                const res = await fetch('/add-to-cart', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ productId })
                });
                const data = await res.json();
                if(data.success) {
                    countEl.innerText = data.cartCount;
                    countEl.classList.add('cart-animate');
                    setTimeout(() => countEl.classList.remove('cart-animate'), 400);
                } else {
                    alert(data.message);
                }
            } catch (error) {
                console.error('Infiltration failed:', error);
            }
        }
    </script>
</body>
</html>
