<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/main.css">
    <title>My Orders — <%= storeName %></title>
</head>
<body class="antialiased text-brand-primary">
    <nav class="glass-panel sticky top-0 z-50 px-8 py-5 flex justify-between items-center shadow-sm border-b border-white/20 animate-fade-in">
        <h1 class="text-2xl font-black tracking-tighter flex items-center gap-3">
            <div class="w-10 h-10 bg-brand-primary rounded-xl flex items-center justify-center text-white"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg></div>
            <span class="heading-gradient uppercase tracking-tighter">Mobile Hub</span>
        </h1>
        <div class="flex items-center space-x-10">
            <a href="/user-dashboard" class="text-xs font-bold uppercase tracking-widest text-zinc-400 hover:text-blue-600 transition-all">Catalog</a>
            <a href="/cart" class="text-xs font-bold uppercase tracking-widest text-zinc-400 hover:text-blue-600 transition-all">Cart</a>
            <a href="/logout" class="bg-rose-500 text-white px-6 py-2.5 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-rose-600 transition-all shadow-lg shadow-rose-500/30 active:scale-95 transform hover:-translate-y-0.5">Logout</a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto py-20 px-8 animate-slide-up">
        <header class="mb-16">
            <h1 class="text-6xl font-black tracking-tighter leading-none mb-4">Hardware<br><span class="heading-gradient">History</span></h1>
            <p class="text-gray-400 font-medium text-sm">Review your past deployments and active shipments.</p>
        </header>

        <% if (orders.length === 0) { %>
            <div class="text-center py-32 glass-panel rounded-[3rem] border-dashed border-2 border-gray-200">
                <p class="text-gray-400 text-xl font-black tracking-tight mb-8">No transaction history found.</p>
                <a href="/user-dashboard" class="inline-block bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-5 px-14 rounded-[2rem] text-xl font-bold shadow-[0_20px_50px_rgba(37,99,235,0.3)] hover:shadow-[0_20px_50px_rgba(37,99,235,0.5)] transition-all transform hover:-translate-y-1 active:scale-95">Initiate First Order</a>
            </div>
        <% } else { %>
            <div class="space-y-10">
                <% orders.forEach(order => { %>
                    <div class="glass-panel p-10 rounded-[3rem] shadow-premium group transition-all hover:scale-[1.01] hover:shadow-premium-hover">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8 pb-6 border-b border-gray-100">
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Batch Identifier</p>
                                <p class="text-2xl font-black tracking-tighter">#<%= order._id.toString().slice(-8).toUpperCase() %></p>
                            </div>
                            <div class="flex items-center gap-4">
                                <span class="<%= order.status === 'Processing' ? 'badge-warning' : order.status === 'Cancelled' ? 'badge-danger' : 'badge-success' %>">
                                    <%= order.status %>
                                </span>
                                <span class="text-2xl font-black tracking-tighter text-brand-secondary"><%= currencySymbol %><%= order.totalAmount %></span>
                            </div>
                        </div>
                        
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                            <% order.items.forEach(item => { %>
                                <div class="bg-gray-50/50 p-6 rounded-[2rem] border border-gray-100 transition-colors group-hover:bg-white">
                                    <p class="text-[10px] font-black uppercase tracking-widest text-brand-secondary mb-1">Device x<%= item.quantity %></p>
                                    <p class="font-black text-brand-primary tracking-tight truncate"><%= item.name %></p>
                                </div>
                            <% }) %>
                        </div>

                        <div class="mt-8 flex items-center justify-between">
                            <p class="text-[10px] font-black uppercase tracking-widest text-gray-400">Deployed: <%= order.createdAt.toDateString() %></p>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>
</body>
</html>