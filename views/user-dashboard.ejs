<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/main.css">
    <title><%= storeName %> | Premium Mobile Collection</title>
</head>
<body class="bg-[#fbfbfd] text-[#1d1d1f] antialiased">
    <nav class="bg-white/80 backdrop-blur-md sticky top-0 z-50 px-12 py-4 flex justify-between items-center border-b border-gray-100 animate-fade-in">
        <h1 class="text-xl font-bold tracking-tight">
            <a href="/"><%= storeName %>.</a>
        </h1>
        <div class="flex items-center space-x-10">
            <% if (user) { %>
                <a href="/my-orders" class="nav-link hover:text-[#0071e3]">Orders</a>
                <a href="/logout" class="nav-link text-red-500">Logout</a>
            <% } else { %>
                <a href="/login" class="nav-link">Login</a>
                <a href="/register" class="bg-black text-white px-4 py-1.5 rounded-full text-xs font-bold hover:scale-105 transition-transform">Sign up</a>
            <% } %>
            <a href="/cart" class="relative hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                <span id="count" class="absolute -top-2 -right-2 bg-[#0071e3] text-white text-[9px] font-bold w-4 h-4 flex items-center justify-center rounded-full"><%= cartCount %></span>
            </a>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-12 px-8 animate-slide-up">
        <!-- Filter & Search Section -->
        <div class="mb-12 flex flex-col lg:flex-row lg:items-center justify-between gap-8 animate-fade-in">
            <div>
                <h2 class="text-4xl font-bold tracking-tight">Shop. <span class="text-gray-400">The best devices are here.</span></h2>
            </div>
            
            <form action="/user-dashboard" method="GET" class="flex items-center gap-4">
                <div class="relative">
                    <input type="text" name="search" value="<%= search %>" placeholder="Search devices..." 
                        class="bg-gray-100 border-none rounded-full px-6 py-2 w-64 text-sm focus:ring-1 focus:ring-blue-500">
                </div>
                
                <select name="brand" onchange="this.form.submit()" 
                    class="bg-white border-gray-200 rounded-full px-4 py-2 text-sm font-semibold cursor-pointer">
                    <option value="">All Brands</option>
                    <% brands.forEach(b => { %>
                        <option value="<%= b %>" <%= selectedBrand === b ? 'selected' : '' %>><%= b %></option>
                    <% }) %>
                </select>
                
                <% if (search || selectedBrand) { %>
                    <a href="/user-dashboard" class="text-[10px] font-black uppercase tracking-widest text-rose-500 hover:text-rose-700 px-4">Reset</a>
                <% } %>
            </form>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <% products.forEach(product => { %>
                <div class="bg-white rounded-3xl p-6 flex flex-col h-full shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-500 group animate-scale-in">
                    <div class="relative mb-6 aspect-square flex items-center justify-center">
                        <img src="/image/<%= product.image || 'default-phone.jpg' %>" 
                             class="h-44 w-44 object-contain transition-transform duration-500 group-hover:scale-110" 
                             onerror="this.src='/image/default-phone.jpg'">
                    </div>
                    
                    <div class="flex-grow text-center">
                        <span class="text-[10px] font-bold text-[#0071e3] uppercase mb-1 block"><%= product.brand %></span>
                        <h3 class="text-lg font-bold mb-2"><%= product.name %></h3>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="text-[10px] bg-gray-50 text-gray-500 px-2 py-1 rounded mx-auto"><%= product.specs.storage %></span>
                        </div>
                    </div>
                    
                    <div class="flex flex-col gap-4 mt-auto">
                        <span class="text-xl font-bold tracking-tight"><%= currencySymbol %><%= product.price %></span>
                        <% if (parseInt(product.stock) > 0) { %>
                            <button onclick="addToCart('<%= product._id %>')" class="bg-[#0071e3] text-white py-2 rounded-full text-xs font-bold hover:bg-[#0077ed]">Add to Cart</button>
                        <% } else { %>
                            <span class="text-red-500 text-[10px] font-bold uppercase">Out of stock</span>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Pagination Controls -->
        <% if (totalPages > 1) { %>
            <div class="flex justify-center items-center mt-20 space-x-4">
                <% if (hasPrevPage) { %>
                    <a href="?page=<%= prevPage %>&search=<%= search %>&brand=<%= selectedBrand %>" class="w-12 h-12 glass-panel flex items-center justify-center rounded-2xl text-gray-400 hover:text-brand-primary transition-all shadow-soft">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
                    </a>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <% if (i === currentPage) { %>
                        <span class="w-12 h-12 flex items-center justify-center bg-brand-primary text-white rounded-2xl font-black shadow-glow"><%= i %></span>
                    <% } else { %>
                        <a href="?page=<%= i %>&search=<%= search %>&brand=<%= selectedBrand %>" class="w-12 h-12 flex items-center justify-center glass-panel text-gray-400 rounded-2xl font-bold hover:text-brand-primary transition-all hover:scale-105"><%= i %></a>
                    <% } %>
                <% } %>

                <% if (hasNextPage) { %>
                    <a href="?page=<%= nextPage %>&search=<%= search %>&brand=<%= selectedBrand %>" class="w-12 h-12 glass-panel flex items-center justify-center rounded-2xl text-gray-400 hover:text-brand-primary transition-all shadow-soft">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
                    </a>
                <% } %>
            </div>
        <% } %>
    </main>

    <script>
        async function addToCart(productId) {
            try {
                const res = await fetch('/add-to-cart', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ productId })
                });
                const data = await res.json();
                if(data.success) {
                    document.getElementById('count').innerText = data.cartCount;
                } else {
                    alert(data.message);
                }
            } catch (error) {
                alert('Error adding to cart: ' + error.message);
            }
        }
    </script>
</body>
</html>