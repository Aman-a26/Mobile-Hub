<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { background-color: #020617; color: white; font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-card { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .accent-gradient { background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%); }
        .text-gradient { background: linear-gradient(135deg, #fff 0%, #94a3b8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    </style>
    <title>Inventory Control | <%= storeName %></title>
</head>
<body class="min-h-screen antialiased selection:bg-cyan-500/30">
    <!-- Decorative Background -->
    <div class="fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-cyan-500/10 blur-[120px]"></div>
        <div class="absolute -bottom-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-blue-600/5 blur-[120px]"></div>
    </div>

    <nav class="sticky top-0 z-50 px-8 py-4 backdrop-blur-xl border-b border-white/5 bg-slate-950/50">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <h1 class="text-2xl font-black italic tracking-tighter text-white uppercase group flex items-center gap-3">
                <div class="w-10 h-10 accent-gradient rounded-xl flex items-center justify-center text-slate-950 shadow-lg shadow-cyan-500/20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /></svg>
                </div>
                <span class="hidden sm:inline">Admin Panel</span>
            </div>
            <div class="flex items-center gap-8">
                <a href="/admin-dashboard" class="text-[10px] font-black uppercase tracking-widest <%= ui.currentPath === '/admin-dashboard' ? 'text-cyan-400' : 'text-gray-500 hover:text-white' %> transition-all">Inventory</a>
                <a href="/admin/orders" class="text-[10px] font-black uppercase tracking-widest <%= ui.currentPath === '/admin/orders' ? 'text-cyan-400' : 'text-gray-500 hover:text-white' %> transition-all">Orders</a>
                <a href="/logout" class="text-[10px] font-black uppercase tracking-widest px-5 py-2 rounded-full border border-red-500/20 text-red-400 hover:bg-red-500/10 transition-all">Exit</a>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-12 px-6">
        <div class="flex flex-col sm:flex-row justify-between items-end gap-8 mb-16">
            <div>
                <p class="text-cyan-500 font-black tracking-[0.3em] uppercase text-[10px] mb-4">Core Module: STOCK_MGMT</p>
                <h1 class="text-6xl font-black tracking-tighter text-gradient leading-none">Inventory<br>Control.</h1>
            </div>
            <a href="/admin/add-product" class="accent-gradient text-slate-950 py-4 px-8 rounded-2xl font-black text-[10px] uppercase tracking-widest shadow-xl shadow-cyan-500/20 hover:scale-105 transition-all flex items-center gap-3">
                <span class="text-xl leading-none">+</span> New Product
            </a>
        </div>

        <div class="glass-card rounded-[2.5rem] overflow-hidden border border-white/5">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-950/50 border-b border-white/5">
                            <th class="px-8 py-6 text-[10px] font-black text-gray-500 uppercase tracking-[0.2em]">Hardware Module</th>
                            <th class="px-8 py-6 text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] text-center">Origin</th>
                            <th class="px-8 py-6 text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] text-center">Inventory</th>
                            <th class="px-8 py-6 text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] text-right">Valuation</th>
                            <th class="px-8 py-6 text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] text-right">Operations</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% products.forEach(product => { %>
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="px-8 py-6">
                                    <div class="flex items-center gap-6">
                                        <div class="relative w-16 h-16 bg-slate-950/50 rounded-2xl flex items-center justify-center p-2 border border-white/5 group-hover:border-cyan-500/20 transition-all">
                                            <img src="<%= product.image ? (product.image.startsWith('/') ? product.image : '/' + product.image) : '/image/default-phone.jpg' %>" 
                                                 class="w-full h-full object-contain transition-transform group-hover:scale-110"
                                                 onerror="this.src='/image/default-phone.jpg'">
                                        </div>
                                        <div>
                                            <p class="font-bold text-white group-hover:text-cyan-400 transition-colors"><%= product.name %></p>
                                            <p class="text-[9px] text-gray-500 font-black uppercase tracking-widest mt-1"><%= product.specs.storage %> • <%= product.specs.ram %></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-8 py-6 text-center">
                                    <span class="text-[9px] font-black text-cyan-400 bg-cyan-400/5 px-4 py-1.5 rounded-full border border-cyan-400/20 uppercase tracking-widest"><%= product.brand %></span>
                                </td>
                                <td class="px-8 py-6 text-center">
                                    <span class="font-black text-lg tracking-tighter <%= product.stock < 5 ? 'text-red-500' : 'text-white' %>"><%= product.stock %></span>
                                </td>
                                <td class="px-8 py-6 text-right font-black text-white italic text-lg"><%= currencySymbol %><%= formatPrice(product.price) %></td>
                                <td class="px-8 py-6 text-right">
                                    <div class="flex items-center justify-end gap-3">
                                        <a href="/admin/edit/<%= product._id %>" class="text-[10px] font-black uppercase tracking-widest text-gray-500 hover:text-cyan-400 transition-all">Edit</a>
                                        <form action="/admin/toggle-status/<%= product._id %>" method="POST" class="inline">
                                            <button class="text-[10px] font-black uppercase tracking-widest <%= product.active ? 'text-gray-500 hover:text-white' : 'text-amber-500/50 hover:text-amber-500' %> transition-all">
                                                <%= product.active ? 'Deactivate' : 'Restore' %>
                                            </button>
                                        </form>
                                        <form action="/admin/delete/<%= product._id %>" method="POST" class="inline" onsubmit="return confirm('Confirm hardware decommissioning?')">
                                            <button class="text-[10px] font-black uppercase tracking-widest text-red-500/50 hover:text-red-500 transition-all">Purge</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="flex justify-center items-center mt-20 gap-3">
                <% if (hasPrevPage) { %>
                    <a href="?page=<%= prevPage %>" class="w-12 h-12 flex items-center justify-center rounded-2xl border border-white/10 text-gray-500 hover:text-white hover:border-cyan-500/30 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
                    </a>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="?page=<%= i %>" 
                       class="w-12 h-12 flex items-center justify-center rounded-2xl font-black text-sm transition-all <%= i === currentPage ? 'accent-gradient text-slate-950' : 'border border-white/10 text-gray-500 hover:text-white' %>">
                        <%= i %>
                    </a>
                <% } %>

                <% if (hasNextPage) { %>
                    <a href="?page=<%= nextPage %>" class="w-12 h-12 flex items-center justify-center rounded-2xl border border-white/10 text-gray-500 hover:text-white hover:border-cyan-500/30 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
                    </a>
                <% } %>
            </div>
        <% } %>
    </main>
</body>
</html>