<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Join MobileHub</title>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-6">
    <div class="bg-white p-12 rounded-[40px] shadow-2xl w-full max-w-md">
        <h2 class="text-3xl font-black text-gray-900 mb-2">Create Account</h2>
        <p class="text-gray-400 font-medium mb-8">Join the community of tech enthusiasts.</p>

        <form action="/register" method="POST" class="space-y-4">
            <input type="text" name="name" placeholder="Full Name" required class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
            <input type="email" name="email" placeholder="Email Address" required class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
            <input type="password" name="password" placeholder="Create Password" required class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
            
            <button type="submit" class="w-full py-5 bg-black text-white rounded-2xl font-bold hover:bg-gray-800 transition shadow-xl">
                Get Started
            </button>
        </form>

        <p class="mt-8 text-center text-sm font-bold text-gray-400">
            Already a member? <a href="/login" class="text-blue-600 hover:underline">Sign In</a>
        </p>
    </div>
</body>
</html>