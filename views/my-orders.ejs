<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { background-color: #020617; color: white; font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-card { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .accent-gradient { background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%); }
        .text-gradient { background: linear-gradient(135deg, #fff 0%, #94a3b8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    </style>
    <title>My Orders | <%= storeName %></title>
</head>
<body class="min-h-screen antialiased selection:bg-cyan-500/30">
    <div class="fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-cyan-500/10 blur-[120px]"></div>
        <div class="absolute -bottom-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-blue-600/5 blur-[120px]"></div>
    </div>

    <nav class="sticky top-0 z-50 px-8 py-4 backdrop-blur-xl border-b border-white/5 bg-slate-950/50">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-8">
                <a href="/" class="text-2xl font-black italic tracking-tighter text-white uppercase group">
                    <span class="text-cyan-500 group-hover:text-white transition-colors duration-300">MobileHub</span>.
                </a>
                <div class="hidden md:flex gap-6">
                    <% ui.nav.forEach(item => { %>
                        <a href="<%= item.path %>" class="text-[10px] font-black uppercase tracking-[0.2em] <%= ui.currentPath === item.path ? 'text-cyan-400' : 'text-gray-500 hover:text-white' %> transition-all">
                            <%= item.label %>
                        </a>
                    <% }) %>
                </div>
            </div>
            <div class="flex items-center gap-6">
                <a href="/cart" class="relative group p-2 rounded-xl hover:bg-white/5 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 group-hover:text-cyan-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                    <span id="count" class="absolute -top-1 -right-1 accent-gradient text-[9px] font-black w-4 h-4 flex items-center justify-center rounded-full border border-slate-950">
                        <%= cartCount %>
                    </span>
                </a>
                <a href="/logout" class="text-[10px] font-black uppercase tracking-widest px-5 py-2 rounded-full border border-red-500/20 text-red-400 hover:bg-red-500/10 transition-all">Exit</a>
            </div>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto py-20 px-6">
        <h1 class="text-6xl font-black tracking-tighter text-gradient mb-16 leading-none">Order<br>History.</h1>

        <% if (orders.length === 0) { %>
            <div class="text-center py-24 glass-card rounded-[3rem]">
                <p class="text-gray-500 text-xl font-bold uppercase tracking-widest mb-10">No deployments found.</p>
                <a href="/user-dashboard" class="inline-block accent-gradient text-slate-950 px-10 py-4 rounded-2xl font-black uppercase tracking-[0.2em] text-[10px] shadow-2xl shadow-cyan-500/20 active:scale-95 transform transition-all">Start Shopping</a>
            </div>
        <% } else { %>
            <div class="space-y-8">
                <% orders.forEach(order => { %>
                    <div class="glass-card rounded-[2.5rem] overflow-hidden group border border-white/5 hover:border-white/10 transition-all">
                        <div class="p-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 border-b border-white/5 bg-white/5">
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-cyan-500 mb-1">REFERENCE: #<%= order._id.toString().slice(-8).toUpperCase() %></p>
                                <p class="text-xs font-bold text-gray-400"><%= order.createdAt.toDateString() %></p>
                            </div>
                            <div class="flex items-center gap-4">
                                <span class="px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-widest border border-current bg-opacity-10
                                    <%= order.status === 'Processing' ? 'border-amber-500/20 text-amber-400 bg-amber-500' : 
                                       order.status === 'Cancelled' ? 'border-rose-500/20 text-rose-400 bg-rose-500' : 
                                       order.status === 'Shipping' ? 'border-blue-500/20 text-blue-400 bg-blue-500' :
                                       'border-emerald-500/20 text-emerald-400 bg-emerald-500' %>">
                                    <%= order.status %>
                                </span>
                                <p class="text-2xl font-black italic text-white"><%= currencySymbol %><%= formatPrice(order.totalAmount) %></p>
                            </div>
                        </div>
                        <div class="p-8 space-y-4">
                            <% order.items.forEach(item => { %>
                                <div class="flex items-center gap-6 group/item">
                                    <div class="w-14 h-14 bg-slate-950/50 rounded-xl p-2 border border-white/5 flex items-center justify-center">
                                        <img src="<%= (item.product && item.product.image) ? (item.product.image.startsWith('/') ? item.product.image : '/' + item.product.image) : '/image/default-phone.jpg' %>" 
                                             class="w-full h-full object-contain"
                                             onerror="this.src='/image/default-phone.jpg'">
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-sm font-black text-white group-hover/item:text-cyan-400 transition-colors"><%= item.name %></p>
                                        <p class="text-[9px] text-gray-500 uppercase font-black tracking-widest mt-1">QTY: <%= item.quantity %> • <%= currencySymbol %><%= formatPrice(item.price) %></p>
                                    </div>
                                    <% if (order.status === 'Delivered') { %>
                                        <a href="/user-dashboard" class="text-[9px] font-black uppercase tracking-widest text-cyan-500 hover:text-white transition-colors">Reorder</a>
                                    <% } %>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>
</body>
</html>