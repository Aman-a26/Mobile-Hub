<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title><%= storeName %></title>
</head>
<body class="bg-gray-50/50">
    <nav class="bg-white border-b sticky top-0 z-50 px-8 py-4 flex justify-between items-center shadow-sm">
        <h1 class="text-2xl font-black text-blue-600 uppercase tracking-tighter"><%= storeName %></h1>
        <div class="flex items-center space-x-6">
            <% if (user) { %>
                <span class="text-gray-400 text-xs font-bold uppercase tracking-widest hidden md:block">Welcome, <span class="text-gray-900"><%= user.name %></span></span>
                <a href="/my-orders" class="text-gray-600 hover:text-blue-600 font-bold transition">My Orders</a>
                <a href="/logout" class="bg-red-50 text-red-600 px-4 py-2 rounded-xl font-bold hover:bg-red-600 hover:text-white transition">Logout</a>
            <% } else { %>
                <a href="/login" class="text-gray-600 font-bold hover:text-blue-600 transition">Login</a>
                <a href="/register" class="bg-blue-600 text-white px-5 py-2 rounded-xl font-bold hover:bg-blue-700 transition">Signup</a>
            <% } %>
            <a href="/cart" class="relative group p-2">
                <span class="text-2xl transition-transform group-hover:scale-110 block">🛒</span>
                <span id="count" class="absolute -top-1 -right-1 bg-blue-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-full ring-4 ring-white"><%= cartCount %></span>
            </a>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto p-10">
        <!-- Order Status Notifications -->
        <% if (user && orderNotifications && orderNotifications.length > 0) { %>
            <div class="mb-10 space-y-3">
                <% orderNotifications.forEach(notif => { %>
                    <div class="flex items-center justify-between p-5 rounded-[1.5rem] border shadow-sm transition-all hover:shadow-md
                        <%= notif.status === 'Cancelled' ? 'bg-red-50 border-red-100 text-red-900' : 'bg-blue-50 border-blue-100 text-blue-900' %>">
                        <div class="flex items-center gap-5">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center bg-white shadow-sm text-lg">
                                <%= notif.status === 'Cancelled' ? '🚫' : '📦' %>
                            </div>
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-widest opacity-50 mb-0.5">Order Notification</p>
                                <p class="font-bold leading-tight">Order #<%= notif._id.toString().slice(-6).toUpperCase() %> status changed to <span class="underline decoration-2"><%= notif.status %></span></p>
                            </div>
                        </div>
                        <a href="/my-orders" class="text-[10px] font-black uppercase tracking-widest px-4 py-2 bg-white rounded-xl shadow-sm hover:scale-105 transition-transform">View Order</a>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <!-- Filter & Search Section -->
        <div class="mb-12 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <h2 class="text-4xl font-extrabold text-gray-900 tracking-tight">Our Collection</h2>
                <p class="text-gray-500 mt-1">Discover the next generation of mobile performance.</p>
            </div>
            
            <form action="/user-dashboard" method="GET" class="flex flex-wrap items-center gap-3">
                <div class="relative">
                    <input type="text" name="search" value="<%= search %>" placeholder="Search devices..." 
                        class="pl-10 pr-4 py-2.5 bg-white border border-gray-100 rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none w-64 shadow-sm transition-all">
                    <span class="absolute left-3 top-3 text-gray-400">🔍</span>
                </div>
                
                <select name="brand" onchange="this.form.submit()" 
                    class="px-4 py-2.5 bg-white border border-gray-100 rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none font-bold text-gray-600 shadow-sm cursor-pointer">
                    <option value="">All Brands</option>
                    <% brands.forEach(b => { %>
                        <option value="<%= b %>" <%= selectedBrand === b ? 'selected' : '' %>><%= b %></option>
                    <% }) %>
                </select>
                
                <% if (search || selectedBrand) { %>
                    <a href="/user-dashboard" class="text-xs font-black uppercase tracking-widest text-red-500 hover:text-red-700 ml-2">Clear</a>
                <% } %>
            </form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <% products.forEach(product => { %>
                <div class="bg-white p-6 rounded-[2rem] shadow-sm hover:shadow-2xl hover:shadow-blue-100/50 transition-all border border-gray-50 group flex flex-col h-full">
                    <div class="relative mb-6 overflow-hidden rounded-2xl bg-gray-50 p-4">
                        <img src="/image/<%= product.image || 'default-phone.jpg' %>" 
                             class="h-48 w-full object-contain group-hover:scale-110 transition-transform duration-500" 
                             onerror="this.src='/image/default-phone.jpg'">
                    </div>
                    
                    <div class="flex-grow">
                        <p class="text-[10px] font-black text-blue-600 uppercase tracking-[0.2em] mb-1"><%= product.brand %></p>
                        <h3 class="text-xl font-bold text-gray-900 mb-2"><%= product.name %></h3>
                        <div class="flex gap-2 mb-4">
                            <span class="text-[10px] font-bold bg-gray-100 text-gray-500 px-2 py-1 rounded-md uppercase"><%= product.specs.storage %></span>
                            <span class="text-[10px] font-bold bg-gray-100 text-gray-500 px-2 py-1 rounded-md uppercase"><%= product.specs.ram %> RAM</span>
                        </div>
                    </div>
                    
                    <div class="flex items-center justify-between pt-4 border-t border-gray-50 mt-auto">
                        <% if (parseInt(product.stock) > 0) { %>
                            <button onclick="addToCart('<%= product._id %>')" class="bg-gray-900 text-white px-5 py-2.5 rounded-2xl font-bold hover:bg-blue-600 transition-all shadow-md active:scale-95">Add to Cart</button>
                        <% } else { %>
                            <span class="text-red-500 text-xs font-black uppercase tracking-widest py-2.5">Sold Out</span>
                        <% } %>
                        <span class="text-2xl font-black text-gray-900 tracking-tighter">$<%= product.price %></span>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Pagination Controls -->
        <% if (totalPages > 1) { %>
            <div class="flex justify-center items-center mt-16 space-x-3">
                <% if (hasPrevPage) { %>
                    <a href="?page=<%= prevPage %>&search=<%= search %>&brand=<%= selectedBrand %>" class="p-3 bg-white border border-gray-100 text-gray-400 rounded-2xl hover:text-blue-600 transition-colors">←</a>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <% if (i === currentPage) { %>
                        <span class="w-10 h-10 flex items-center justify-center bg-blue-600 text-white rounded-2xl font-bold shadow-lg shadow-blue-100"><%= i %></span>
                    <% } else { %>
                        <a href="?page=<%= i %>&search=<%= search %>&brand=<%= selectedBrand %>" class="w-10 h-10 flex items-center justify-center bg-white border border-gray-100 text-gray-600 rounded-2xl hover:border-blue-500 transition-all"><%= i %></a>
                    <% } %>
                <% } %>

                <% if (hasNextPage) { %>
                    <a href="?page=<%= nextPage %>&search=<%= search %>&brand=<%= selectedBrand %>" class="p-3 bg-white border border-gray-100 text-gray-400 rounded-2xl hover:text-blue-600 transition-colors">→</a>
                <% } %>
            </div>
        <% } %>
    </main>

    <script>
        async function addToCart(productId) {
            try {
                const res = await fetch('/add-to-cart', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ productId })
                });
                const data = await res.json();
                if(data.success) {
                    document.getElementById('count').innerText = data.cartCount;
                } else {
                    alert(data.message);
                }
            } catch (error) {
                alert('Error adding to cart: ' + error.message);
            }
        }
    </script>
</body>
</html>