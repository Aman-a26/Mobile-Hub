<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Edit Device</title>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen">
    <div class="bg-white p-10 rounded-3xl shadow-xl w-full max-w-lg">
        <h2 class="text-3xl font-black text-gray-900 mb-8">Edit Device</h2>
        <form action="/admin/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" class="space-y-5">
            <div class="grid grid-cols-2 gap-4">
                <input type="text" name="name" value="<%= product.name %>" placeholder="Device Name" required class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
                <input type="text" name="brand" value="<%= product.brand %>" placeholder="Brand" required class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div class="grid grid-cols-3 gap-4">
                <input type="text" name="storage" value="<%= product.specs.storage %>" placeholder="Storage (e.g. 256GB)" class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
                <input type="text" name="ram" value="<%= product.specs.ram %>" placeholder="RAM (e.g. 12GB)" class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
                <input type="number" name="price" value="<%= product.price %>" placeholder="Price" required class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <input type="number" name="stock" value="<%= product.stock %>" placeholder="Stock" class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
            
            <div>
                <label class="block text-gray-700 font-bold mb-2">Product Image</label>
                <input type="file" name="image" accept="image/*" class="w-full p-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none">
                <% if (product.image) { %>
                    <p class="text-sm text-gray-500 mt-2">Current image: <%= product.image %></p>
                <% } %>
            </div>
            
            <button type="submit" class="w-full py-5 bg-blue-600 text-white rounded-2xl font-bold hover:bg-blue-700 transition transform hover:-translate-y-1">Update Device</button>
        </form>
    </div>
</body>
</html>
                <label class="block mb-1 text-gray-600 font-semibold text-sm">Current Image</label>
                <% if (product.image) { %>
                    <img src="<%= product.image %>" alt="<%= product.name %>" class="w-24 h-24 object-cover rounded-md mb-2 border border-gray-200">
                <% } else { %>
                    <p class="text-xs text-gray-400 mb-2">No image available.</p>
                <% } %>
                
                <label class="block mb-1 text-gray-600 font-semibold text-sm">Upload New Image (Optional)</label>
                <input type="file" name="image" accept="image/*"
                       class="w-full file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 p-3 border border-gray-300 rounded-md text-base outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/10 transition-all">
            </div>

            <div class="btn-container flex gap-3 mt-6">
                <button type="submit" class="btn-save flex-[2] bg-gradient-to-r from-indigo-500 to-purple-600 text-white p-3 rounded-md font-semibold hover:opacity-90 transition-opacity">
                    Save Changes
                </button>
                <a href="/admin-dashboard" class="btn-cancel flex-1 bg-gray-200 text-gray-700 no-underline text-center p-3 rounded-md font-semibold hover:bg-gray-300 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>

</body>
</html>