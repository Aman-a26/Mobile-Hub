<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Inventory - Admin Panel</title>
</head>
<body class="bg-gray-50">
    <nav class="bg-white border-b sticky top-0 z-50 px-8 py-4 flex justify-between items-center shadow-sm">
        <h1 class="text-2xl font-black text-blue-600 uppercase tracking-tighter">Admin Panel</h1>
        <div class="flex items-center space-x-6">
            <a href="/admin-dashboard" class="text-blue-600 font-bold border-b-2 border-blue-600 pb-1">Inventory</a>
            <a href="/admin/orders" class="text-gray-600 hover:text-blue-600 font-bold transition">Orders</a>
            <a href="/logout" class="bg-red-50 text-red-600 px-4 py-2 rounded-xl font-bold hover:bg-red-600 hover:text-white transition">Logout</a>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto p-10">
        <div class="flex justify-between items-center mb-10">
            <h2 class="text-4xl font-extrabold text-gray-900 tracking-tight">Product Catalog</h2>
            <a href="/admin/add-product" class="bg-blue-600 text-white px-6 py-3 rounded-2xl font-bold hover:bg-blue-700 transition shadow-lg shadow-blue-100 flex items-center gap-2">
                <span class="text-xl">+</span> Add New Device
            </a>
        </div>

        <div class="bg-white rounded-[2.5rem] shadow-sm border border-gray-100 overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-50/50 border-b border-gray-100">
                    <tr>
                        <th class="px-8 py-5 font-bold text-gray-400 uppercase text-[10px] tracking-widest">Image</th>
                        <th class="px-8 py-5 font-bold text-gray-400 uppercase text-[10px] tracking-widest">Device</th>
                        <th class="px-8 py-5 font-bold text-gray-400 uppercase text-[10px] tracking-widest text-center">Brand</th>
                        <th class="px-8 py-5 font-bold text-gray-400 uppercase text-[10px] tracking-widest text-center">Stock</th>
                        <th class="px-8 py-5 font-bold text-gray-400 uppercase text-[10px] tracking-widest text-right">Price</th>
                        <th class="px-8 py-5 font-bold text-gray-400 uppercase text-[10px] tracking-widest text-center">Visibility</th>
                        <th class="px-8 py-5 font-bold text-gray-400 uppercase text-[10px] tracking-widest text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% products.forEach(product => { %>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-8 py-5">
                                <img src="/image/<%= product.image || 'default-phone.jpg' %>" class="w-12 h-12 object-contain bg-gray-50 rounded-xl p-1 border border-gray-100">
                            </td>
                            <td class="px-8 py-5">
                                <p class="font-bold text-gray-900"><%= product.name %></p>
                                <p class="text-[10px] text-gray-400 uppercase font-black"><%= product.specs.storage %> / <%= product.specs.ram %></p>
                            </td>
                            <td class="px-8 py-5 text-center">
                                <span class="text-xs font-bold text-gray-600 bg-gray-100 px-3 py-1 rounded-lg uppercase tracking-wider"><%= product.brand %></span>
                            </td>
                            <td class="px-8 py-5 text-center">
                                <span class="font-mono font-bold <%= product.stock < 5 ? 'text-red-500' : 'text-gray-900' %>"><%= product.stock %></span>
                            </td>
                            <td class="px-8 py-5 text-right font-black text-blue-600">$<%= product.price %></td>
                            <td class="px-8 py-5 text-center">
                                <span class="px-3 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest <%= product.active ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' %>">
                                    <%= product.active ? 'Public' : 'Hidden' %>
                                </span>
                            </td>
                            <td class="px-8 py-5 text-right">
                                <div class="flex items-center justify-end space-x-4">
                                    <a href="/admin/edit/<%= product._id %>" class="text-gray-400 hover:text-blue-600 font-black text-[10px] uppercase tracking-widest transition">Edit</a>
                                    <form action="/admin/toggle-status/<%= product._id %>" method="POST" class="inline">
                                        <button class="text-gray-400 hover:text-indigo-600 font-black text-[10px] uppercase tracking-widest transition">
                                            <%= product.active ? 'Hide' : 'Show' %>
                                        </button>
                                    </form>
                                    <form action="/admin/delete/<%= product._id %>" method="POST" class="inline">
                                        <button class="text-red-300 hover:text-red-600 font-black text-[10px] uppercase tracking-widest transition">Del</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- Pagination Controls -->
        <% if (totalPages > 1) { %>
            <div class="flex justify-center items-center mt-12 space-x-2">
                <% if (hasPrevPage) { %>
                    <a href="?page=<%= prevPage %>" class="px-4 py-2 bg-white border border-gray-100 text-gray-500 rounded-xl hover:text-blue-600 transition">
                        &larr;
                    </a>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <% if (i === currentPage) { %>
                        <span class="w-10 h-10 flex items-center justify-center bg-blue-600 text-white rounded-xl font-bold shadow-lg shadow-blue-100">
                            <%= i %>
                        </span>
                    <% } else { %>
                        <a href="?page=<%= i %>" class="w-10 h-10 flex items-center justify-center bg-white border border-gray-100 text-gray-600 rounded-xl hover:border-blue-500 transition">
                            <%= i %>
                        </a>
                    <% } %>
                <% } %>

                <% if (hasNextPage) { %>
                    <a href="?page=<%= nextPage %>" class="px-4 py-2 bg-white border border-gray-100 text-gray-500 rounded-xl hover:text-blue-600 transition">
                        &rarr;
                    </a>
                <% } %>
            </div>
        <% } %>
    </main>
</body>
</html>