<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { background-color: #020617; color: white; font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-card { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .accent-gradient { background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%); }
        .text-gradient { background: linear-gradient(135deg, #fff 0%, #94a3b8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .input-glow:focus { box-shadow: 0 0 20px rgba(34, 211, 238, 0.15); border-color: rgba(34, 211, 238, 0.4); }
        .field-label { font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: #94a3b8; margin-bottom: 0.5rem; display: block; }
    </style>
    <title>Edit Hardware | <%= storeName %></title>
</head>
<body class="min-h-screen antialiased selection:bg-cyan-500/30">
    <div class="fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-cyan-500/10 blur-[120px]"></div>
        <div class="absolute -bottom-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-blue-600/5 blur-[120px]"></div>
    </div>

    <nav class="sticky top-0 z-50 px-8 py-4 backdrop-blur-xl border-b border-white/5 bg-slate-950/50">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-8">
                <a href="/" class="text-2xl font-black italic tracking-tighter text-white uppercase group">
                    <span class="text-cyan-500 group-hover:text-white transition-colors duration-300">MobileHub</span>.
                </a>
            </div>
            <div class="flex items-center gap-6">
                <a href="/admin-dashboard" class="text-[10px] font-black uppercase tracking-widest px-5 py-2 rounded-full border border-white/10 text-gray-400 hover:text-white transition-all">Cancel Edit</a>
                <a href="/logout" class="text-[10px] font-black uppercase tracking-widest px-5 py-2 rounded-full border border-red-500/20 text-red-400 hover:bg-red-500/10 transition-all">Exit</a>
            </div>
        </div>
    </nav>

    <main class="max-w-3xl mx-auto py-16 px-6">
        <div class="glass-card rounded-[3rem] p-12 relative overflow-hidden">
            <div class="absolute top-0 right-0 p-8">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-cyan-500/30">ID: <%= product._id.toString().slice(-6).toUpperCase() %></span>
            </div>

            <header class="mb-12">
                <h1 class="text-5xl font-black tracking-tighter text-gradient leading-tight">Modify<br>Hardware.</h1>
                <p class="text-gray-500 font-bold mt-2 text-[10px] uppercase tracking-widest">Update specifications for <%= product.name %></p>
            </header>

            <form action="/admin/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" class="space-y-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="field-label">Device Model</label>
                        <input type="text" name="name" value="<%= product.name %>" required 
                            class="w-full bg-slate-900/40 border border-white/10 rounded-2xl px-6 py-4 text-sm outline-none input-glow transition-all focus:bg-slate-900/60 text-white">
                    </div>
                    <div>
                        <label class="field-label">Manufacturer</label>
                        <input type="text" name="brand" value="<%= product.brand %>" required 
                            class="w-full bg-slate-900/40 border border-white/10 rounded-2xl px-6 py-4 text-sm outline-none input-glow transition-all focus:bg-slate-900/60 text-white">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="field-label">Price (<%= currencySymbol %>)</label>
                        <input type="number" name="price" value="<%= product.price %>" required 
                            class="w-full bg-slate-900/40 border border-white/10 rounded-2xl px-6 py-4 text-sm outline-none input-glow transition-all focus:bg-slate-900/60 text-white">
                    </div>
                    <div>
                        <label class="field-label">Stock Units</label>
                        <input type="number" name="stock" value="<%= product.stock %>" required 
                            class="w-full bg-slate-900/40 border border-white/10 rounded-2xl px-6 py-4 text-sm outline-none input-glow transition-all focus:bg-slate-900/60 text-white">
                    </div>
                    <div>
                        <label class="field-label">Category</label>
                        <input type="text" name="category" value="<%= product.category %>" 
                            class="w-full bg-slate-900/40 border border-white/10 rounded-2xl px-6 py-4 text-sm outline-none input-glow transition-all focus:bg-slate-900/60 text-white">
                    </div>
                </div>

                <div class="p-8 bg-slate-950/50 rounded-[2rem] border border-white/5 space-y-6">
                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-cyan-500/50">Technical Specifications</p>
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <label class="field-label">Storage</label>
                            <input type="text" name="storage" value="<%= product.specs.storage %>" required 
                                class="w-full bg-slate-900/40 border border-white/10 rounded-2xl px-6 py-4 text-sm outline-none input-glow transition-all focus:bg-slate-900/60 text-white">
                        </div>
                        <div>
                            <label class="field-label">RAM</label>
                            <input type="text" name="ram" value="<%= product.specs.ram %>" required 
                                class="w-full bg-slate-900/40 border border-white/10 rounded-2xl px-6 py-4 text-sm outline-none input-glow transition-all focus:bg-slate-900/60 text-white">
                        </div>
                    </div>
                </div>

                <div class="space-y-4">
                    <label class="field-label">Visual Asset</label>
                    <div class="flex items-center gap-6 p-4 glass-card rounded-2xl border-white/5">
                        <img src="<%= product.image ? (product.image.startsWith('/') ? product.image : '/' + product.image) : '/image/default-phone.jpg' %>" 
                             class="w-20 h-20 object-contain rounded-xl bg-slate-950/50 p-2" id="preview">
                        <div class="flex-1">
                            <p class="text-[9px] font-black text-gray-500 uppercase tracking-widest mb-2">Overwrite current asset</p>
                            <div class="relative group">
                                <input type="file" name="image" onchange="previewImg(this)" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                <div class="w-full bg-slate-900/40 border border-white/10 rounded-xl px-4 py-3 text-[10px] flex items-center justify-between group-hover:border-cyan-500/40 transition-all">
                                    <span class="text-gray-600 font-bold uppercase">Browse Files...</span>
                                    <div class="accent-gradient text-slate-950 p-1.5 rounded-lg">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                        </svg>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" 
                    class="accent-gradient w-full py-6 rounded-3xl text-slate-950 text-sm font-black uppercase tracking-[0.2em] shadow-2xl shadow-cyan-500/20 hover:scale-[1.02] active:scale-95 transition-all">
                    Commit Changes
                </button>
            </form>
        </div>
    </main>

    <script>
        function previewImg(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('preview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>
</html>